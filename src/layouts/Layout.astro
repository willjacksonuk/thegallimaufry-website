---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";

import "../styles/global.css";
import "../styles/responsive.css";

const {
  title = "The Gallimaufry History Podcast",
  description = "Two enthusiasts of the past explore the weird, the overlooked, and the occasionally ridiculous. New episodes monthly, crafted in a carpet shop basement.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--tg-font-lato" />
    <ClientRouter />
  </head>
  <body>
    <!-- Header -->
    <header>
      <div class="container">
      <nav>
        <span class="nav-logo">
          <a href="/">The Gallimaufry</a>
        </span>
        <div class="nav-items">
          <a class="nav-item" href="/about">About</a>
        </div>
      </nav>
    </header>

    <!-- Main content  -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer container">
      <span class="site-footer-brand">The Gallimaufry</span>
      <span class="site-footer-copyright"
        >© {new Date().getFullYear()} The Gallimaufry - All Rights Reserved</span
      >
    </footer>
  </body>
</html>
