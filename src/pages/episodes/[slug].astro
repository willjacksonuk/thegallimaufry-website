---
import Layout from "../../layouts/Layout.astro";
import EpisodeHero from "../../components/EpisodeHero.astro";
import EpisodePlayer from "../../components/EpisodePlayer.astro";
import type { Episode } from "../../types/episode";
import { durationToIso, getEpisodes } from "../../lib/buzzsprout";

import convert from "url-slug";

export async function getStaticPaths() {
  const episodes = await getEpisodes();

  return episodes.map((episode) => ({
    params: { slug: convert(episode.title, { dictionary: { Æ: "A" } }) },
    props: { episode },
  }));
}

const { episode } = Astro.props as { episode: Episode };

const plainDescription = episode.description
  ? episode.description
      .replace(/<[^>]*>/g, "")
      .replace(/&nbsp;/g, " ")
      .replace(/&amp;/g, "&")
      .replace(/&lt;/g, "<")
      .replace(/&gt;/g, ">")
      .replace(/&quot;/g, '"')
      .trim()
      .slice(0, 155)
  : undefined;

const episodeSlug = convert(episode.title, { dictionary: { Æ: "A" } });
const episodeUrl = `https://thegallimaufry.show/episodes/${episodeSlug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  url: episodeUrl,
  name: episode.title,
  description: plainDescription,
  datePublished: episode.published_at,
  duration: durationToIso(episode.duration),
  associatedMedia: {
    "@type": "MediaObject",
    contentUrl: episode.audio_url,
    encodingFormat: "audio/mpeg",
  },
  partOfSeries: {
    "@type": "PodcastSeries",
    name: "The Gallimaufry",
    url: "https://thegallimaufry.show",
  },
  ...(episode.episode_number && { episodeNumber: episode.episode_number }),
  ...(episode.season_number && { seasonNumber: episode.season_number }),
  ...(episode.artwork_url && { image: episode.artwork_url }),
};

---

<Layout
  title={episode.title}
  description={plainDescription}
  image={episode.artwork_url || undefined}
  imageAlt={`Artwork for ${episode.title}`}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- Hero section -->
  <EpisodeHero episode={episode} />

  <!-- Audio player -->
  <EpisodePlayer episode={episode} />

  <!--- Episode info -->
  <section class="container">
    <div class="episode-info-container">
      <div class="episode-info">
        <h2 class="section-header">Episode Notes</h2>
        <div class="episode-notes" set:html={episode.description} />

        <!-- Subscribe section -->
        <section class="container subscribe-section">
          <h2 class="section-header">Listen on</h2>
          <div class="subscribe-buttons">
            <a
              href="https://podcasts.apple.com/podcast/id1541207040"
              target="_blank"
              class="subscribe-button">Apple Podcasts</a
            >
            <a
              href="https://open.spotify.com/show/4QO6YrQMbF8KtgpGCjmlQZ"
              target="_blank"
              class="subscribe-button">Spotify</a
            >
            <a
              href="https://music.amazon.com/podcasts/275087d3-2808-4d10-a949-e3c193ea0e92"
              target="_blank"
              class="subscribe-button">Amazon Music</a
            >
            <a
              href="https://feeds.buzzsprout.com/1460611.rss"
              target="_blank"
              class="subscribe-button">RSS</a
            >
          </div>
        </section>
      </div>
      <div class="episode-info">
        {
          episode.artwork_url && (
            <img
              src={episode.artwork_url}
              alt={`Artword for ${episode.title}`}
              width="100%"
            />
          )
        }
      </div>
    </div>
  </section>
</Layout>
