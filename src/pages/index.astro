---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

import { getEpisodes } from "../lib/buzzsprout";
import convert from "url-slug";
import { durationToReadable, dateToReadable } from "../lib/buzzsprout";

const episodes = await getEpisodes();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "PodcastSeries",
  name: "The Gallimaufry",
  url: "https://thegallimaufry.show",
  description: "Two enthusiasts of the past explore the weird, the overlooked, and the occasionally ridiculous. New episodes monthly, crafted in a carpet shop basement.",
  image: "https://thegallimaufry.show/og-default.jpg",
  webFeed: "https://feeds.buzzsprout.com/1460611.rss",
};
---

<Layout
  title="The Gallimaufry History Podcast"
  description="Two enthusiasts of the past explore the weird, the overlooked, and the occasionally ridiculous. New episodes monthly, crafted in a carpet shop basement."
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- Hero section -->
  <Hero />

  <!-- Episode listing -->
  <section class="container">
    <div class="episode-list">
      <div class="episode-list-header">
        <h2 class="episode-list-header-title">Episodes</h2>
        <span class="episode-list-header-count"
          >{episodes.length} total</span
        >
      </div>

      {
        episodes.map((episode) => (
          <div class="episode-row">
            <span class="episode-number">{episode.episode_number}</span>
            <span class="episode-title">
              <h3>
                <a href={`/episodes/${convert(episode.title, { dictionary: { Æ: "A" } })}`}>
                  {episode.title}
                </a>
              </h3>
            </span>
            <div class="episode-data">
              <span class="episode-date">
                {dateToReadable(episode.published_at)}
              </span>
              <span class="episode-length">
                {durationToReadable(episode.duration)}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>