---
import { getEpisodes } from "../lib/buzzsprout";
import convert from "url-slug";
import "../styles/global.css";

const episodes = await getEpisodes();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Gallimaufry History Podcast</title>
  </head>
  <body>
    <main>

      <!-- Navigation section -->
      <nav>
        <span class="brand">The Gallimaufry</span>
        <div class="nav-items">
          <a class="nav-item" href="#">About</a>
          <a class="nav-item" href="#">Subscribe</a>
          <!-- The theme toggle will go here -->
          <button>Light</button>
        </div>
      </nav>

      <!-- Hero section -->
      <div class="hero">
        <p class="hero-eyebrow">A hodgepodge history podcast &nbsp;·&nbsp; Est. 2020</p>
        <h1 class="hero-title">The Gallimaufry</h1>
        <p class="hero-description">
          Two lovers of the past on the weird, the wonderful, and the often
          overlooked. Crafted in a carpet shop basement. New episodes every
          month.
        </p>
        <div class="hero-pills">
          <button class="hero-pill">Apple Podcasts</button>
          <button class="hero-pill">Spotify</button>
          <button class="hero-pill">Amazon Music</button>
          <button class="hero-pill">RSS</button>
        </div>
      </div>

      <!-- Old episode listing - to be replaced -->
      <ul>
        {
          episodes.map((episode) => (
            <li>
              <a
                href={`/episodes/${convert(episode.title, { dictionary: { Æ: "A" } })}`}
              >
                <h2>{episode.title}</h2>
              </a>
              <p>
                {new Date(episode.published_at).toLocaleDateString("en-GB", {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })}
              </p>
              <p>{episode.summary}</p>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
