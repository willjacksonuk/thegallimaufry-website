---
import { getEpisodes } from "../lib/buzzsprout";
import convert from "url-slug";
import { formatDuration } from "../lib/buzzsprout";
import "../styles/global.css";

const episodes = await getEpisodes();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Gallimaufry History Podcast</title>
  </head>
  <body>
    <main>

      <!-- Header -->
      <header>
        <nav>
          <span class="brand">The Gallimaufry</span>
          <div class="nav-items">
            <a class="nav-item" href="#">About</a>
            <a class="nav-item" href="#">Subscribe</a>
            <!-- The theme toggle will go here -->
            <button>Light</button>
          </div>
        </nav>
      </header>

      <!-- Hero section -->
      <section>
        <div class="hero">
          <p class="hero-eyebrow">
            A hodgepodge history podcast &nbsp;·&nbsp; Est. 2020
          </p>
          <h1 class="hero-title">The Gallimaufry</h1>
          <p class="hero-description">
            Two lovers of the past pontificate on the weird, the wonderful, and the often
            overlooked. Crafted in a carpet shop basement. New episodes every
            month.
          </p>
          <div class="hero-pills">
            <a
              href="https://podcasts.apple.com/podcast/id1541207040"
              class="hero-pill">Apple Podcasts</a
            >
            <a
              href="https://open.spotify.com/show/4QO6YrQMbF8KtgpGCjmlQZ"
              class="hero-pill">Spotify</a
            >
            <a
              href="https://music.amazon.com/podcasts/275087d3-2808-4d10-a949-e3c193ea0e92"
              class="hero-pill">Amazon Music</a
            >
            <a href="https://feeds.buzzsprout.com/1460611.rss" class="hero-pill"
              >RSS</a
            >
          </div>
        </div>
      </section>

      <!-- New episode listing -->
      <section>
        <div class="episode-list">
          <div class="episode-header">
            <span class="episode-header-title">Episodes</span>
            <span class="episode-header-count"
              >{Object.keys(episodes).length} total</span
            >
          </div>

          {
            episodes.map((episode) => (
              <div class="episode-row">
                <span class="episode-number">{episode.episode_number}</span>
                <span class="episode-title">
                  <a
                    href={`/episodes/${convert(episode.title, { dictionary: { Æ: "A" } })}`}
                  >
                    <p>{episode.title}</p>
                  </a>
                </span>
                <div class="episode-data">
                  <span class="episode-date">
                    {new Date(episode.published_at).toLocaleDateString(
                      "en-GB",
                      {
                        day: "numeric",
                        month: "long",
                        year: "numeric",
                      },
                    )}
                  </span>
                  <span class="episode-length">
                    {formatDuration(episode.duration)}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
        <a class="see-all-episodes" href="#">See all 40 episodes →</a>
      </section>
    </main>
  </body>
</html>
